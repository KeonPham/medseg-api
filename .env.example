# ─── Production (docker-compose.prod.yml) ───
POSTGRES_PASSWORD=change_me_to_a_random_string

# Domain for Caddy auto-HTTPS (set in Caddyfile, not here)
# Current production: lungmedseg.duckdns.org
# For local dev without domain, use :80 in Caddyfile

# ─── App defaults (override if needed) ───
MODEL_DIR=./models
DEFAULT_MODEL=hybrid
IMAGE_SIZE=512
DATABASE_URL=sqlite:///./data/predictions.db
