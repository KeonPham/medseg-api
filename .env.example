# API Configuration
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=info

# Model Configuration
MODEL_DIR=./models
DEFAULT_MODEL=hybrid
MODEL_DEVICE=cpu

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000
MLFLOW_EXPERIMENT_NAME=medseg-api

# Database (production)
DATABASE_URL=sqlite:///./medseg.db

# Auth
API_KEY_ENABLED=false
API_KEY=changeme

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Monitoring
ENABLE_METRICS=true
